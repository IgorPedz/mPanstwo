        "items": {
            "createAccount": {
                "question": "How can I create an account?",
                "answer": "Click the registration button and fill out the account creation form."
            },
            "editProfile": {
                "question": "Can I change my profile information?",
                "answer": "Yes, you can edit all your information in the “My Profile” section."
            },
            "deleteAccount": {
                "question": "How can I delete my account?",
                "answer": "The account deletion option is available in the security settings under the “My Profile” section."
            },
            "resetPassword": {
                "question": "How can I reset my password?",
                "answer": "Click “Forgot password” on the login screen and follow the instructions."
            },
            "dataSecurity": {
                "question": "Is my data secure?",
                "answer": "Yes, user data is encrypted and properly secured."
            },
            "accountHijacked": {
                "question": "What should I do if someone gains access to my account?",
                "answer": "Immediately change your password and contact the platform administration."
            },
            "freeUsage": {
                "question": "Is the website completely free to use?",
                "answer": "Yes, the website is intended for public use and is completely free."
            },
            "contentModeration": {
                "question": "Is the content on the website moderated?",
                "answer": "Yes, content is moderated by the platform administration to remove offensive and vulgar comments."
            },
            "contactAdmin": {
                "question": "How can I contact the administration?",
                "answer": "You can use the contact form or email mpanstwosupport@gmail.com."
            },
            "technicalProblem": {
                "question": "How can I report a technical issue?",
                "answer": "Report technical issues through the “Contact” section."
            },
            "platformRules": {
                "question": "Where can I find the platform rules?",
                "answer": "The rules are available in the “Documents” section under “Platform Rules”."
            },
            "reportViolation": {
                "question": "How can I report a community guideline violation?",
                "answer": "Each comment has an option to report violations."
            },
            "rulePenalties": {
                "question": "What penalties apply to users who violate the rules?",
                "answer": "All penalties are described in the platform regulations."
            }
        }
